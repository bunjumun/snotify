.DS_Store

# Audio lives in Supabase Storage now (index.html reads it from the 'tracks' bucket) —
# nothing under tracks/ needs to be committed or exposed via the repo/GitHub Pages.
tracks/**/*.wav
tracks/**/*.aif
tracks/**/*.aiff
tracks/**/*.flac
tracks/**/*.m4a
tracks/**/*.mp3
tracks/**/*.ogg

# Trash: deleted songs archived locally until permanently removed via the player
.trash/
